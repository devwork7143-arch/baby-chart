# Required — get these from the Discord Developer Portal (see README)
DISCORD_TOKEN=paste-your-bot-token-here
FEEDING_CHANNEL_ID=paste-the-channel-id-here

# Optional — defaults shown
# BABY_NAME=Baby           # shown in help text and web chart title
# BABY_DOB=2025-01-15      # YYYY-MM-DD; enables the next-nap prediction on SF (omit to disable)
# HOST=127.0.0.1           # use 0.0.0.0 for cloud/remote access
# PORT=8000
# DATA_DIR=/data           # where feedings.json is stored; set for cloud volumes
#
# NOTE: timezone (TZ) is NOT a .env var — it must be set in the host environment
# (Railway variables / `docker -e TZ=...` / your shell), because .env is loaded
# too late to change the process timezone. See the README.
